{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "TokenLift 설정",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "provider": { "type": "string", "description": "활성 백엔드 이름(ollama | nemoclaw | ...)" },
    "ollama": {
      "type": "object",
      "properties": {
        "host": { "type": "string", "description": "Ollama 엔드포인트 URL" },
        "timeoutMs": { "type": "integer", "minimum": 1000, "description": "요청 타임아웃(ms)" },
        "keepAlive": { "type": "string", "description": "모델 메모리 상주 시간(예: 30m)" },
        "numCtx": { "type": "integer", "minimum": 512, "description": "기본 컨텍스트 윈도우 토큰" }
      }
    },
    "providers": {
      "type": "object",
      "description": "추가 백엔드(provider) 정의. ollama 외 백엔드를 키로 추가.",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "type": { "type": "string", "enum": ["ollama", "openai-compat"], "description": "어댑터 타입" },
          "host": { "type": "string", "description": "백엔드 호스트 URL" },
          "apiPath": { "type": "string", "description": "(openai-compat) API 경로 prefix, 기본 /v1" },
          "apiKey": { "type": "string", "description": "(openai-compat) Bearer 키(비밀은 apiKeyEnv 권장)" },
          "apiKeyEnv": { "type": "string", "description": "(openai-compat) Bearer 키를 읽을 환경변수명" },
          "extraHeaders": { "type": "object", "description": "(openai-compat) 추가 HTTP 헤더" },
          "extraBody": { "type": "object", "description": "(openai-compat) 모든 요청 body 에 병합할 비표준 필드. 예: llama.cpp 의 chat_template_kwargs, reasoning_format. 호출별 값이 우선." },
          "sampling": {
            "type": "object",
            "description": "(openai-compat) 모델별 권장 샘플링 기본값. 전역 generation 보다 우선하고 --temp/--top-p 등 명시 플래그보다는 낮음. 예: GLM-5.2 → temperature 1.0/top_p 0.95/top_k 40.",
            "properties": {
              "temperature": { "type": "number", "minimum": 0, "maximum": 2 },
              "top_p": { "type": "number", "minimum": 0, "maximum": 1 },
              "top_k": { "type": "integer", "minimum": 0 },
              "min_p": { "type": "number", "minimum": 0, "maximum": 1 },
              "repeat_penalty": { "type": "number", "minimum": 0 }
            }
          },
          "supportsFIM": { "type": "boolean", "description": "(openai-compat) /v1/completions(FIM) 지원 여부" },
          "keepAlive": { "type": "string", "description": "(ollama) 모델 상주 시간" },
          "numCtx": { "type": "integer", "description": "(ollama) 컨텍스트 윈도우" },
          "timeoutMs": { "type": "integer", "description": "요청 타임아웃(ms)" },
          "models": {
            "type": "array", "items": { "type": "string" },
            "description": "/v1/models 미지원 시 모델명 수동 목록"
          },
          "routing": {
            "type": "object",
            "properties": {
              "default": { "type": "string" },
              "byTask": { "type": "object", "additionalProperties": { "type": "string" } }
            }
          }
        },
        "required": ["type"]
      }
    },
    "routing": {
      "type": "object",
      "properties": {
        "default": { "type": "string" },
        "byTask": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "fallback": { "type": "string" }
      },
      "required": ["default"]
    },
    "roles": {
      "type": "object",
      "description": "에이전트 역할 → 폴백 체인(oh-my-openagent fallbackChain 반영). 앞에서부터 호출 가능한 첫 백엔드 사용, 실패 시 자동 강등. 'claude'/'codebase-memory-mcp' 는 종단 라벨(직접 처리).",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "chain": {
            "type": "array",
            "description": "우선순위(싼/적합→폴백) 백엔드 목록. provider 이름(문자열) 또는 {provider, model}.",
            "items": {
              "oneOf": [
                { "type": "string" },
                {
                  "type": "object",
                  "properties": { "provider": { "type": "string" }, "model": { "type": "string" } },
                  "required": ["provider"]
                }
              ]
            }
          },
          "provider": { "type": "string", "description": "(구형) 단일 provider — chain 권장" },
          "style": { "type": "string", "description": "작업 스타일(orchestration/deep-reasoning/bulk-code/retrieval/judgment)" },
          "desc": { "type": "string" }
        }
      }
    },
    "escalation": {
      "type": "array",
      "items": { "type": "string" },
      "description": "비용 최소화 에스컬레이션 사다리(싼→비싼). 충분한 가장 싼 단계를 먼저 사용."
    },
    "pricing": {
      "type": "object",
      "description": "절감 추정용 Bedrock 단가(USD per 1M tokens) + 월 예산",
      "properties": {
        "label": { "type": "string" },
        "inputPer1M": { "type": "number", "minimum": 0 },
        "outputPer1M": { "type": "number", "minimum": 0 },
        "monthlyBudgetUsd": { "type": "number", "minimum": 0, "description": "한 달 Bedrock(Claude) 목표 예산(USD). stats 가 이번 달 절감액과 예산 대비 지표를 표시." }
      }
    },
    "thresholds": {
      "type": "object",
      "properties": {
        "delegateMinOutputLines": { "type": "integer", "minimum": 0 },
        "delegateMinFileLines": { "type": "integer", "minimum": 0 },
        "delegateMinFiles": { "type": "integer", "minimum": 0 }
      }
    },
    "generation": {
      "type": "object",
      "properties": {
        "temperature": { "type": "number", "minimum": 0, "maximum": 2 },
        "topP": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "logging": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "file": { "type": "string" }
      }
    },
    "security": {
      "type": "object",
      "description": "NemoClaw 보안 게이트웨이 자동 적용(tokenlift secure). Bedrock 트래픽을 게이트웨이로 우회(필터)시키고 온프렘은 직결(예외), 민감 폴더는 Claude Code 에서 접근 차단한다.",
      "properties": {
        "enabled": { "type": "boolean", "description": "보안 자동적용 활성화" },
        "claudeSettingsPath": { "type": "string", "description": "적용 대상 Claude Code settings.json 경로" },
        "gateway": {
          "type": "object",
          "properties": {
            "url": { "type": "string", "description": "NemoClaw 게이트웨이 URL(Bedrock 트래픽 경유지)" },
            "authTokenEnv": { "type": "string", "description": "게이트웨이 인증 토큰 환경변수명" }
          }
        },
        "bedrock": {
          "type": "object",
          "properties": {
            "region": { "type": "string" },
            "runtimeHost": { "type": "string", "description": "AWS Bedrock Runtime 호스트" },
            "useMantle": { "type": "boolean", "description": "Anthropic API 형태 Mantle 엔드포인트 사용 여부" }
          }
        },
        "exemptHosts": {
          "type": "array", "items": { "type": "string" },
          "description": "게이트웨이/필터 우회(직결)할 신뢰 호스트 = 보안 예외(온프렘 provider host 와 일치)"
        },
        "sensitivePaths": {
          "type": "array", "items": { "type": "string" },
          "description": "유출 차단할 민감 경로/글롭 → Claude Code permissions.deny(Read) + sandbox.denyRead 로 변환"
        },
        "sensitivePatterns": {
          "type": "array", "items": { "type": "string" },
          "description": "내용 기반 기밀 신호(라우팅용). 감지 시 tokenlift route 가 Bedrock 전송 금지 + 사내 GLM 강제. 문자열(포함) 또는 \"/정규식/i\". 내장 패턴(키/시크릿/.internal/주민번호/기밀 키워드)에 추가됨."
        },
        "allowReadRoots": {
          "type": "array", "items": { "type": "string" },
          "description": "(선택) OS 샌드박스 읽기 허용 루트"
        }
      }
    }
  }
}
