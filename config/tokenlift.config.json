{
  "$schema": "./tokenlift.config.schema.json",
  "provider": "onprem-v100",
  "_provider_note": "Ollama 는 사내 H200/V100 서버에서 구동(로컬 PC 아님). 기본 위임=최저가 onprem-v100. 로컬 ollama 는 선택(개발용).",
  "ollama": {
    "host": "http://localhost:11434",
    "timeoutMs": 600000,
    "keepAlive": "30m",
    "numCtx": 8192
  },
  "providers": {
    "nemoclaw": {
      "type": "openai-compat",
      "host": "http://localhost:8000",
      "apiPath": "/v1",
      "apiKeyEnv": "NEMOCLAW_API_KEY",
      "supportsFIM": false,
      "models": [],
      "_comment": "NVIDIA NemoClaw/NIM (OpenAI 호환). host/모델명/키를 사내 환경에 맞게 교체. routing.byTask 의 모델명은 실제 배포된 NIM 모델명이어야 함.",
      "routing": {
        "default": "qwen/qwen2.5-coder-32b-instruct",
        "byTask": {
          "gen": "qwen/qwen2.5-coder-32b-instruct",
          "edit": "qwen/qwen2.5-coder-32b-instruct",
          "test": "qwen/qwen2.5-coder-32b-instruct",
          "refactor": "qwen/qwen2.5-coder-32b-instruct",
          "translate": "qwen/qwen2.5-coder-32b-instruct",
          "explain": "meta/llama-3.1-8b-instruct",
          "review": "qwen/qwen2.5-coder-32b-instruct",
          "agent": "nvidia/llama-3.1-nemotron-70b-instruct",
          "reason": "nvidia/llama-3.1-nemotron-70b-instruct",
          "docs": "meta/llama-3.1-8b-instruct",
          "fast": "meta/llama-3.1-8b-instruct"
        }
      }
    },
    "onprem-h200": {
      "type": "ollama",
      "host": "http://h200.internal:11434",
      "keepAlive": "30m",
      "numCtx": 16384,
      "_comment": "사내 H200 Ollama 서버(최신 오픈 모델 다수). Oracle 역할(어려운 추론·대형). NemoClaw/NIM 이면 type:openai-compat+apiKeyEnv 로 교체. 태그는 실제 pull 모델로.",
      "routing": {
        "default": "qwen2.5-coder:32b",
        "byTask": {
          "reason": "deepseek-r1:70b",
          "agent": "devstral:24b",
          "gen": "qwen2.5-coder:32b",
          "edit": "qwen2.5-coder:32b",
          "test": "qwen2.5-coder:32b",
          "refactor": "qwen3:32b",
          "translate": "qwen2.5-coder:32b",
          "review": "deepseek-r1:70b",
          "explain": "qwen3:32b",
          "docs": "llama3.3:70b",
          "complete": "qwen2.5-coder:7b"
        }
      }
    },
    "onprem-glm": {
      "type": "openai-compat",
      "host": "http://h200.internal:8080",
      "apiPath": "/v1",
      "apiKeyEnv": "ONPREM_API_KEY",
      "supportsFIM": false,
      "timeoutMs": 1800000,
      "models": ["glm-5.2-q8", "glm-5.2-q4", "glm-5.2-q2"],
      "sampling": { "temperature": 1.0, "top_p": 0.95, "top_k": 40, "min_p": 0.0 },
      "_comment": "GLM-5.2(744B MoE) 멀티 양자화 tier — llama.cpp(llama-server)로 서빙(scripts/run-glm-fleet.sh), 여러 사용자가 공유 host 로 접속(멀티유저). q8=최고품질/q4=균형/q2=빠름. 앞단 게이트웨이(NemoClaw compatible-endpoint/llama-swap)로 여러 tier 를 host 하나에 합치거나, 포트별 직결이면 provider 를 tier 별로 분리. model id 는 fleet alias 와 일치. timeoutMs 는 대형 콜드로드 대비(NemoClaw #2403 주의). docs/16 참조.",
      "routing": {
        "default": "glm-5.2-q4",
        "byTask": {
          "reason": "glm-5.2-q8",
          "agent": "glm-5.2-q8",
          "review": "glm-5.2-q8",
          "gen": "glm-5.2-q4",
          "edit": "glm-5.2-q4",
          "test": "glm-5.2-q4",
          "refactor": "glm-5.2-q4",
          "translate": "glm-5.2-q4",
          "explain": "glm-5.2-q2",
          "docs": "glm-5.2-q2",
          "fast": "glm-5.2-q2"
        }
      }
    },
    "onprem-v100": {
      "type": "ollama",
      "host": "http://v100.internal:11434",
      "keepAlive": "30m",
      "numCtx": 8192,
      "_comment": "사내 V100 Ollama 서버(GGUF Q4/Q5 는 Volta 동작). Coder 역할(대량·최저가). 태그는 실제 pull 모델로.",
      "routing": {
        "default": "qwen2.5-coder:14b",
        "byTask": {
          "gen": "qwen2.5-coder:14b",
          "edit": "qwen2.5-coder:14b",
          "test": "qwen2.5-coder:14b",
          "refactor": "qwen2.5-coder:14b",
          "translate": "qwen2.5-coder:14b",
          "reason": "deepseek-r1:14b",
          "review": "qwen2.5-coder:14b",
          "explain": "qwen3:8b",
          "docs": "llama3.1:8b",
          "fast": "gemma3:12b",
          "complete": "qwen2.5-coder:1.5b-base"
        }
      }
    }
  },
  "roles": {
    "lead": { "style": "orchestration(mechanics)", "chain": ["claude"], "desc": "오케스트레이션·계획·위임·통합 (Bedrock)" },
    "explorer": { "style": "retrieval", "chain": ["codebase-memory-mcp"], "desc": "코드 탐색/검색/영향분석 (그래프, 무료)" },
    "coder": { "style": "bulk-code", "chain": ["onprem-v100", "onprem-h200"], "desc": "대량·정형 생성 (V100→H200)" },
    "oracle": { "style": "deep-reasoning", "chain": ["onprem-glm", "onprem-h200", "onprem-v100", "claude"], "desc": "어려운 추론·대형 생성 (GLM-5.2→H200→V100→Bedrock)" },
    "reviewer": { "style": "judgment", "chain": ["claude"], "desc": "보안·최종 검토·의사결정 (Bedrock)" }
  },
  "escalation": ["codebase-memory-mcp", "onprem-v100", "onprem-h200", "onprem-glm", "claude"],
  "routing": {
    "default": "qwen2.5-coder:14b",
    "byTask": {
      "gen": "qwen2.5-coder:14b",
      "edit": "qwen2.5-coder:14b",
      "test": "qwen2.5-coder:14b",
      "refactor": "qwen2.5-coder:14b",
      "translate": "qwen2.5-coder:14b",
      "explain": "qwen2.5-coder:14b",
      "review": "deepcoder:latest",
      "agent": "devstral:24b",
      "reason": "deepseek-r1:14b",
      "docs": "gemma3:12b",
      "fast": "gemma3:4b",
      "complete": "qwen2.5-coder:1.5b-base"
    },
    "fallback": "gemma3:4b"
  },
  "pricing": {
    "note": "위임으로 절감되는 금액 추정용. 사내 Bedrock 단가에 맞춰 수정하세요. (USD per 1M tokens)",
    "label": "claude-sonnet-on-bedrock",
    "inputPer1M": 3.0,
    "outputPer1M": 15.0
  },
  "thresholds": {
    "comment": "Claude가 자동 위임 여부를 판단할 때 참고하는 휴리스틱 임계값",
    "delegateMinOutputLines": 30,
    "delegateMinFileLines": 300,
    "delegateMinFiles": 3
  },
  "generation": {
    "temperature": 0.1,
    "topP": 0.9
  },
  "logging": {
    "enabled": true,
    "file": "~/.tokenlift/usage.jsonl"
  },
  "security": {
    "enabled": true,
    "_comment": "NemoClaw 보안 게이트웨이 자동 적용(tokenlift secure). Bedrock→게이트웨이(필터), 온프렘→직결(예외), 민감폴더 접근차단. gateway.url/bedrock.region/sensitivePaths 를 사내 환경에 맞게 교체.",
    "claudeSettingsPath": "~/.claude/settings.json",
    "gateway": {
      "url": "http://localhost:8080",
      "authTokenEnv": "NEMOCLAW_GATEWAY_TOKEN"
    },
    "bedrock": {
      "region": "us-east-1",
      "runtimeHost": "bedrock-runtime.us-east-1.amazonaws.com",
      "useMantle": false
    },
    "exemptHosts": ["h200.internal", "v100.internal", "localhost", "127.0.0.1"],
    "sensitivePaths": ["~/.aws/**", "~/.ssh/**", "**/.env", "**/*.pem", "**/*.key", "**/secrets/**"],
    "allowReadRoots": []
  }
}
